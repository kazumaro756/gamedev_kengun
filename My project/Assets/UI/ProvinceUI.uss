.panel {
    position: absolute;
    bottom: 20px;
    right: 20px;
    background-color: rgba(0, 0, 0, 0.8);
    border-radius: 5px;
    padding: 15px;
    width: 250px;
}

.header-text {
    font-size: 22px;
    -unity-font-style: bold;
    color: rgb(255, 255, 255);
    margin-bottom: 10px;
}

.info-text {
    font-size: 16px;
    color: rgb(200, 200, 200);
    margin-bottom: 5px;
}